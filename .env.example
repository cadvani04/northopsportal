# ─── Required for Vercel ───────────────────────────────────────────────────────
# Postgres — get free at https://neon.tech (copy connection string)
DATABASE_URL="postgresql://user:password@host/dbname?sslmode=require"

# Auth — REQUIRED or you get "Server configuration" error
# Generate: openssl rand -base64 32
AUTH_SECRET="your-secret-here"

# Your live URL
NEXT_PUBLIC_APP_URL="https://northopsportal.vercel.app"

# ─── Optional ──────────────────────────────────────────────────────────────────
FIREFLIES_WEBHOOK_SECRET="northops-fireflies-secret-change-me"
OPENAI_API_KEY=""
RESEND_API_KEY=""
EMAIL_FROM="NorthOps <onboarding@resend.dev>"

# ─── Local dev only (SQLite) ─────────────────────────────────────────────────
# DATABASE_URL="file:./prisma/dev.db"
# NEXT_PUBLIC_APP_URL="http://localhost:3000"
