# ─── Required for Vercel ───────────────────────────────────────────────────────
# Postgres — get free at https://neon.tech (copy connection string)
DATABASE_URL="postgresql://user:password@host/dbname?sslmode=require"

# Auth — REQUIRED or you get "Server configuration" error
# Generate: openssl rand -base64 32
AUTH_SECRET="your-secret-here"

# Your live URL
NEXT_PUBLIC_APP_URL="https://northopsportal.vercel.app"

# ─── Optional ──────────────────────────────────────────────────────────────────
# Vercel Blob — required for agreement PDF uploads in production
# Create at: Vercel project → Storage → Blob → connect to project
BLOB_READ_WRITE_TOKEN=""
# Fireflies — API key required to import past meetings; webhook works without it (minimal data)
# Get at: Fireflies → Settings → Developer → API Key
FIREFLIES_API_KEY=""
FIREFLIES_WEBHOOK_SECRET="northops-fireflies-secret-change-me"
# Claude — for AI meeting → task/deliverable extraction (Fireflies import + webhooks)
# Get at: https://console.anthropic.com/settings/keys
ANTHROPIC_API_KEY=""
# Optional: override default model (claude-sonnet-4-20250514)
# ANTHROPIC_MODEL="claude-sonnet-4-20250514"
# Inbound email → deliverable (any provider that POSTs to your webhook)
INBOUND_EMAIL_ADDRESS="dev@northops.org"
INBOUND_EMAIL_SECRET="generate-a-long-random-string"
# Optional outbound email (leave unset to skip sending)
RESEND_API_KEY=""
EMAIL_FROM="NorthOps <notifications@northops.org>"

# ─── Local dev only (SQLite) ─────────────────────────────────────────────────
# DATABASE_URL="file:./prisma/dev.db"
# NEXT_PUBLIC_APP_URL="http://localhost:3000"
