# See https://help.github.com/articles/ignoring-files/ for more about ignoring files.

# dependencies
/node_modules
/.pnp
.pnp.*
.yarn/*
!.yarn/patches
!.yarn/plugins
!.yarn/releases
!.yarn/versions

# testing
/coverage

# next.js
/.next/
/out/

# production
/build

# misc
.DS_Store
*.pem

# debug
npm-debug.log*
yarn-debug.log*
yarn-error.log*
.pnpm-debug.log*

# env files (can opt-in for committing if needed)
.env*
!.env.example

# local database
*.db
*.db-journal

# vercel
.vercel

# uploaded agreement PDFs (local dev)
/public/uploads/agreements/*
!/public/uploads/agreements/.gitkeep
/public/uploads/receipts/*
!/public/uploads/receipts/.gitkeep

# typescript
*.tsbuildinfo
next-env.d.ts

/src/generated/prisma
